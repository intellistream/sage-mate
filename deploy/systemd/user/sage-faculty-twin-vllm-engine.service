[Unit]
Description=Sage Faculty Twin vLLM-HUST inference engine (Qwen3-32B)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__REPO_ROOT__
ExecStart=__REPO_ROOT__/tools/run_vllm_engine.sh
ExecStopPost=__REPO_ROOT__/tools/cleanup_vllm_engine.sh
Restart=on-failure
RestartSec=10
# Graph mode + 32B model loading needs generous startup time
TimeoutStartSec=600
TimeoutStopSec=90
KillMode=control-group

[Install]
WantedBy=default.target
