# Replace these two fields first if you fork this repo for another person.
DIGITAL_TWIN_OWNER_NAME=张书豪
DIGITAL_TWIN_OWNER_ROLE=华中科技大学计算机学院教师
# Auto-detected from the connected LLM when left empty.
DIGITAL_TWIN_MODEL_NAME=
DIGITAL_TWIN_LLM_BASE_URL=http://127.0.0.1:18001/v1
# Replace EMPTY with a real secret before running vLLM-HUST or the local
# OpenAI-compatible proxy. The engine and app/proxy keys must match.
DIGITAL_TWIN_API_KEY=EMPTY

# Public branding
DIGITAL_TWIN_HOMEPAGE_PUBLIC_URL=https://me.sage.org.ai/

# Runtime data repository
# Keep production KB, accounts, memories, logs, and mutable state outside this
# code repo. The recommended private checkout is:
#   /home/shuhao/sage-faculty-twin-runtime-private
DIGITAL_TWIN_RUNTIME_DIR=/home/shuhao/sage-faculty-twin-runtime-private

# Slack /twin slash command.
# Slack app setup:
#   Command: /twin
#   Request URL: https://twin.sage.org.ai/slack/commands/twin
#   Scopes: commands, chat:write
SLACK_TWIN_REQUEST_URL=https://twin.sage.org.ai/slack/commands/twin
SLACK_TWIN_SIGNING_SECRET=
SLACK_TWIN_ALLOWED_USER_IDS=
SLACK_TWIN_VISITOR_PROFILE=lab_member

# Optional inference monitor Slack alerts. Prefer a U... user id for direct
# messages; D... DM channel ids can become inaccessible to the bot.
TWIN_MONITOR_SLACK_BOT_TOKEN=
TWIN_MONITOR_SLACK_USER_ID=
# TWIN_MONITOR_SLACK_CHANNEL_ID=

# Local content and storage
# These default to paths under DIGITAL_TWIN_RUNTIME_DIR. Override only when
# splitting a specific store away from the runtime repo.
# DIGITAL_TWIN_HOMEPAGE_DIR=/path/to/homepage-export
# DIGITAL_TWIN_KNOWLEDGE_BASE_DIR=/path/to/runtime/data/knowledge_base
# Knowledge retrieval backend: sagevdb (recommended) or neuromem
DIGITAL_TWIN_KNOWLEDGE_BACKEND=sagevdb
DIGITAL_TWIN_KNOWLEDGE_SEARCH_CACHE_TTL_SECONDS=300
DIGITAL_TWIN_KNOWLEDGE_SEARCH_CACHE_MAX_ENTRIES=256
# When using sagevdb, use SageANNS backend for ANN retrieval.
DIGITAL_TWIN_SAGEVDB_BACKEND=sage-anns
DIGITAL_TWIN_SAGEVDB_ANNS_ALGORITHM=faiss_hnsw
DIGITAL_TWIN_SAGEVDB_EMBEDDING_BACKEND=hash
# Optional neuromem index setting (only effective when DIGITAL_TWIN_KNOWLEDGE_BACKEND=neuromem).
DIGITAL_TWIN_NEUROMEM_INDEX_TYPE=faiss
# DIGITAL_TWIN_CONVERSATION_MEMORY_DIR=/path/to/runtime/data/conversation_memory

# Scheduling and notifications
# DIGITAL_TWIN_AVAILABILITY_SCHEDULE_PATH=/path/to/runtime/data/availability/current_week.json
DIGITAL_TWIN_BOOKING_NOTIFICATION_EMAIL=faculty@example.edu

# Admin access
DIGITAL_TWIN_ADMIN_USERNAME=admin
DIGITAL_TWIN_ADMIN_PASSWORD=change-me-admin-password
DIGITAL_TWIN_ADMIN_SESSION_SECRET=change-me-admin-session-secret

# Chat latency / streaming knobs (defaults match production)
# Enable per-token streaming over SSE. Requires the upstream LLM endpoint to
# emit Transfer-Encoding: chunked. Verify with: curl -N -i ... | head — the
# response MUST contain `Transfer-Encoding: chunked`. HTTP/1.0 routers (e.g.
# Python's http.server) silently disable chunked and break streaming.
DIGITAL_TWIN_STREAM_CHAT_ANSWER=true
DIGITAL_TWIN_CHAT_REQUEST_TIMEOUT_SECONDS=80
DIGITAL_TWIN_LLM_TIMEOUT_SECONDS=60
DIGITAL_TWIN_LLM_FAST_ANSWER_MAX_TOKENS=1024
DIGITAL_TWIN_FAST_ANSWER_CONCISE_GUIDANCE_ENABLED=true
DIGITAL_TWIN_CHAT_RUNTIME_PIPELINE_ENABLED=false
DIGITAL_TWIN_WARM_SERVICE_ON_STARTUP=true
DIGITAL_TWIN_CHAT_SSE_KEEPALIVE_SECONDS=15
DIGITAL_TWIN_CHAT_PROMPT_SOFT_CAP_CHARS=12000
DIGITAL_TWIN_FAST_INTENT_CLASSIFIER_ENABLED=true

# Optional vLLM-HUST fixed-prefix cache namespace.
# Uses vLLM's native cache_salt field; no vLLM-HUST changes are required.
DIGITAL_TWIN_KV_FIXED_PREFIX_MATERIALIZATION_ENABLED=true
DIGITAL_TWIN_KV_FIXED_PREFIX_ANCHOR_PREFIX=sage-faculty-twin-fixed-prefix
# Bump this when the fixed system/persona/installed-skill prompt changes.
DIGITAL_TWIN_KV_FIXED_PREFIX_ANCHOR_VERSION=skills-v1
DIGITAL_TWIN_INSTALLED_SKILL_PROMPT_ENABLED=true
# Defaults under DIGITAL_TWIN_RUNTIME_DIR:
# DIGITAL_TWIN_INSTALLED_SKILL_PROMPT_PATH=/path/to/runtime/data/installed_skills/fixed_prompt_skills.md

# Optional web search (Tavily)
DIGITAL_TWIN_WEB_SEARCH_ENABLED=true
DIGITAL_TWIN_WEB_SEARCH_AUTO_TRIGGER=false
DIGITAL_TWIN_WEB_SEARCH_MAX_RESULTS=3
DIGITAL_TWIN_WEB_SEARCH_TIMEOUT_SECONDS=8
# You can also set plain TAVILY_TOKEN in parent env files.
DIGITAL_TWIN_TAVILY_TOKEN=

# Optional systemd OpenAI proxy for vLLM.
VLLM_PROXY_HOST=127.0.0.1
VLLM_PROXY_PORT=18001
VLLM_PROXY_PATH_PREFIX=/v1
VLLM_PROXY_UPSTREAM_BASE_URL=http://127.0.0.1:18000/v1
VLLM_PROXY_UPSTREAM_API_KEY=

# vLLM-HUST engine config (used by sage-faculty-twin-vllm-engine.service).
# The engine always runs inside a Docker container with NPU/GPU devices
# and CANN toolkit pre-installed.  Graph mode is ON (no --enforce-eager).
# TP=4 targets 4× Ascend 910B3 (64 GB HBM each); adjust for your hardware.
VLLM_ENGINE_CONTAINER=vllm-hust
VLLM_ENGINE_BIN=/root/miniconda3/envs/vllm-hust-dev/bin/vllm-hust
VLLM_ENGINE_MODEL_PATH=/data/shared-models/Qwen3-32B
VLLM_ENGINE_PORT=8000
VLLM_ENGINE_TP_SIZE=4
VLLM_ENGINE_MAX_MODEL_LEN=32768
VLLM_ENGINE_GPU_MEM_UTIL=0.85
VLLM_ENGINE_MAX_NUM_SEQS=16
VLLM_ENGINE_DTYPE=bfloat16
# Ascend NPU device selection (e.g. "4,5,6,7"). Leave empty to auto-detect.
ASCEND_RT_VISIBLE_DEVICES=
