# sage-faculty-twin environment template
# Copy to .env and fill in real values:  cp .env.template .env

# ── Digital Twin model config (mytwin-specific) ─────────────────────────────
DIGITAL_TWIN_MODEL_NAME=qwen3-32b
DIGITAL_TWIN_LLM_BASE_URL=http://127.0.0.1:8000/v1
DIGITAL_TWIN_API_KEY=EMPTY

# ── Knowledge backend (sagevdb + SageANNS) ────────────────────────────
# DIGITAL_TWIN_KNOWLEDGE_BACKEND: "sagevdb" (recommended) or "neuromem"
# DIGITAL_TWIN_SAGEVDB_BACKEND:  "sage-anns" (recommended) or "native" (flat index)
#   sage-anns requires the isage-anns PyPI package; auto-installed by
#   tools/run_app_server.sh on first boot if missing.
# DIGITAL_TWIN_SAGEVDB_ANNS_ALGORITHM: ANNS algorithm name (faiss_hnsw, dpg,
#   faiss_flat, faiss_ivf_flat, faiss_ivf_pq, lshapg, nndescent, onlinepq)
# DIGITAL_TWIN_SAGEVDB_EMBEDDING_BACKEND: "hash" (fast) or model name
DIGITAL_TWIN_KNOWLEDGE_BACKEND=sagevdb
DIGITAL_TWIN_SAGEVDB_BACKEND=sage-anns
DIGITAL_TWIN_SAGEVDB_ANNS_ALGORITHM=faiss_hnsw
DIGITAL_TWIN_SAGEVDB_EMBEDDING_BACKEND=hash
# Fallback neuromem index type (only if backend=neuromem)
DIGITAL_TWIN_NEUROMEM_INDEX_TYPE=faiss

# GitHub Personal Access Token (required for cloning private sagellm-* repos)
# Required scopes (classic token): repo, read:org
GITHUB_TOKEN=<your-github-pat>

# Optional: Hugging Face token for model download
HF_ENDPOINT=https://hf-mirror.com
HF_TOKEN=<your-hf-token>

# Optional: PyPI token for private publishing workflows
PYPI_TOKEN=<your-pypi-token>
TAVILY_TOKEN=<your-tavily-token>

# Cloudflare integration
# 1) Put a parent token with "Create Additional Tokens" capability in CLOUDFLARE_BOOTSTRAP_TOKEN.
#    Or use Global API Key mode: set CLOUDFLARE_EMAIL + CLOUDFLARE_GLOBAL_API_KEY.
# 2) Run: python scripts/create_cloudflare_api_token.py --zone-id <ZONE_ID>
# 3) The script writes CLOUDFLARE_API_TOKEN back to this .env.
CLOUDFLARE_ACCOUNT_ID=<your-cf-account-id>
CLOUDFLARE_ZONE_ID=<your-cf-zone-id>
CLOUDFLARE_EMAIL=<your-email>
CLOUDFLARE_GLOBAL_API_KEY=<your-cf-global-api-key>
CLOUDFLARE_BOOTSTRAP_TOKEN=
CLOUDFLARE_API_TOKEN=<your-cf-api-token>

# Large-model API shared credentials
# VLLM_HUST_API_BASE_URL: public-facing OpenAI-compatible endpoint
# VLLM_HUST_API_KEY: shared secret for auth-proxy / external clients
VLLM_HUST_API_BASE_URL=https://api.sage.org.ai/v1
VLLM_HUST_API_KEY=<your-api-key>
