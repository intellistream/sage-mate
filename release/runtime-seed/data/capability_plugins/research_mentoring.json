{
  "plugin_id": "research_mentoring",
  "name": "Research Mentoring Pack",
  "description": "研究方向匹配、研究规划建议和文献阅读指导扩展工作流。",
  "min_app_version": "3.3.0",
  "enabled": true,
  "steps": [
    {
      "step_id": "retrieve_research_overview",
      "description": "检索研究总览和研究主线。",
      "required_inputs": ["question", "profile_context"],
      "produces_outputs": ["research_overview_hits"],
      "side_effect": "none",
      "admin_only": false,
      "timeout_budget_ms": 1500,
      "retry_policy": "idempotent",
      "trace_key": "plugin_research_overview"
    },
    {
      "step_id": "match_research_direction",
      "description": "匹配适合的研究方向和潜在课题。",
      "required_inputs": ["question", "profile_context", "research_overview_hits"],
      "produces_outputs": ["direction_matches"],
      "side_effect": "none",
      "admin_only": false,
      "timeout_budget_ms": 1200,
      "retry_policy": "none",
      "trace_key": "plugin_direction_match"
    },
    {
      "step_id": "retrieve_reading_methodology",
      "description": "检索论文阅读方法论。",
      "required_inputs": ["question", "profile_context"],
      "produces_outputs": ["reading_methodology_hits"],
      "side_effect": "none",
      "admin_only": false,
      "timeout_budget_ms": 1200,
      "retry_policy": "idempotent",
      "trace_key": "plugin_reading_methodology"
    },
    {
      "step_id": "draft_research_plan",
      "description": "起草结构化研究计划草案。",
      "required_inputs": ["question", "direction_matches", "profile_context"],
      "produces_outputs": ["research_plan_draft"],
      "side_effect": "draft_write",
      "admin_only": false,
      "timeout_budget_ms": 2000,
      "retry_policy": "none",
      "trace_key": "plugin_research_plan_draft"
    }
  ],
  "policy_requirements": [],
  "test_scenario_ids": []
}
