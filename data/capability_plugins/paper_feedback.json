{
    "plugin_id": "paper_feedback",
    "name": "Paper Feedback Pack",
    "description": "学生论文反馈工作流：检索写作评分标准、生成结构化修改意见、起草修改说明。",
    "min_app_version": "3.3.0",
    "enabled": true,
    "steps": [
        {
            "step_id": "retrieve_writing_rubric",
            "description": "检索论文写作课程评分标准和常见写作问题，作为反馈依据。",
            "required_inputs": ["question", "profile_context"],
            "produces_outputs": ["writing_rubric_hits"],
            "side_effect": "none",
            "admin_only": false,
            "timeout_budget_ms": 1400,
            "retry_policy": "idempotent",
            "trace_key": "plugin_writing_rubric"
        },
        {
            "step_id": "generate_structured_critique",
            "description": "基于评分标准和论文内容，生成结构化反馈（逻辑、实验、表述等维度）。",
            "required_inputs": ["question", "interaction_intent", "writing_rubric_hits"],
            "produces_outputs": ["structured_critique"],
            "side_effect": "none",
            "admin_only": false,
            "timeout_budget_ms": 2000,
            "retry_policy": "none",
            "trace_key": "plugin_structured_critique"
        },
        {
            "step_id": "draft_revision_notes",
            "description": "起草逐条修改说明草案，经导师审核后发送给学生。",
            "required_inputs": ["question", "structured_critique", "writing_rubric_hits"],
            "produces_outputs": ["revision_notes_draft"],
            "side_effect": "draft_write",
            "admin_only": false,
            "timeout_budget_ms": 2000,
            "retry_policy": "none",
            "trace_key": "plugin_revision_notes_draft"
        }
    ],
    "policy_requirements": [],
    "test_scenario_ids": []
}
